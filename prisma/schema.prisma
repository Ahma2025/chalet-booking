generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          String    @default("GUEST")
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  chalets       Chalet[]
  bookings      Booking[]
}

model Chalet {
  id            String          @id @default(cuid())
  name          String
  description   String
  location      String
  city          String
  mapUrl        String?
  phone         String?
  instagram     String?
  facebook      String?
  whatsapp      String?
  coverImage    String?
  images        ChaletImage[]
  videoUrl      String?
  amenities     Amenity[]
  pricingDays   DayPricing[]
  specialPrices SpecialPrice[]
  discounts     Discount[]
  blockedSlots  BlockedSlot[]
  bookings      Booking[]
  hostId        String
  host          User            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
}

model ChaletImage {
  id        String  @id @default(cuid())
  url       String
  chaletId  String
  chalet    Chalet  @relation(fields: [chaletId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Amenity {
  id       String @id @default(cuid())
  name     String
  icon     String?
  chaletId String
  chalet   Chalet @relation(fields: [chaletId], references: [id], onDelete: Cascade)
}

model DayPricing {
  id            String  @id @default(cuid())
  dayOfWeek     Int
  morningPrice  Float?
  eveningPrice  Float?
  fullDayPrice  Float?
  chaletId      String
  chalet        Chalet  @relation(fields: [chaletId], references: [id], onDelete: Cascade)
}

model SpecialPrice {
  id           String   @id @default(cuid())
  fromDate     DateTime
  toDate       DateTime
  label        String?
  morningExtra Float?
  eveningExtra Float?
  fullDayExtra Float?
  chaletId     String
  chalet       Chalet   @relation(fields: [chaletId], references: [id], onDelete: Cascade)
}

model Discount {
  id         String   @id @default(cuid())
  fromDate   DateTime
  toDate     DateTime
  percentage Float
  chaletId   String
  chalet     Chalet   @relation(fields: [chaletId], references: [id], onDelete: Cascade)
}

model BlockedSlot {
  id       String   @id @default(cuid())
  date     DateTime
  period   String
  chaletId String
  chalet   Chalet   @relation(fields: [chaletId], references: [id], onDelete: Cascade)
}

model Booking {
  id           String    @id @default(cuid())
  chaletId     String
  chalet       Chalet    @relation(fields: [chaletId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  period       String
  totalPrice   Float
  guestName    String
  guestPhone   String
  guestAddress String?
  status       String    @default("PENDING")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}
